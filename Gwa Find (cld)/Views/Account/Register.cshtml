@model GwaFind.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Create an account</h1>
            <p>Join GwaFind to post or find your gwa</p>
        </div>

        <div class="role-selector">
            <p>I am a:</p>
            <div class="role-btns">
                <button type="button" class="role-btn active" onclick="setRole('Seeker', this)">
                    🔍 House seeker
                </button>
                <button type="button" class="role-btn" onclick="setRole('Owner', this)">
                    🏠 Property owner
                </button>
            </div>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Role" id="roleInput" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="FullName">Full name</label>
                <input asp-for="FullName" class="form-control" placeholder="e.g. Sarah Namukasa" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email address</label>
                <input asp-for="Email" class="form-control" placeholder="sarah@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Phone">Phone number</label>
                <input asp-for="Phone" class="form-control" placeholder="+256 7XX XXX XXX" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Min. 8 characters" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-block">Create account</button>
        </form>

        <p class="auth-footer">
            Already have an account?
            <a asp-action="Login">Log in</a>
        </p>
    </div>
</div>

@section Scripts {
    <script>
        function setRole(role, btn) {
            document.getElementById('roleInput').value = role;
            document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
        }
    </script>
}