@model GwaFind.Models.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    var isOwner = User.IsInRole("Owner");
}

<div class="dash-layout">
    <!-- SIDEBAR -->
    <div class="dash-sidebar">
        <div class="dash-user">
            @if (!string.IsNullOrEmpty(ViewBag.ProfilePicture as string))
            {
                <img src="@ViewBag.ProfilePicture" class="dash-avatar-img" />
            }
            else
            {
                <div class="dash-avatar">@(ViewBag.FullName?[0].ToString().ToUpper() ?? "?")</div>
            }
            <div class="dash-user-name">@ViewBag.FullName</div>
            <div class="dash-user-role">@(isOwner ? "Property owner" : "House seeker")</div>
        </div>

        @if (isOwner)
        {
            <a asp-controller="Dashboard" asp-action="Index" class="dash-nav-item">
                <i class="fa-solid fa-chart-bar"></i> Dashboard
            </a>
            <a asp-controller="Dashboard" asp-action="MyListings" class="dash-nav-item">
                <i class="fa-solid fa-list"></i> My listings
            </a>
            <a asp-controller="Listing" asp-action="Create" class="dash-nav-item">
                <i class="fa-solid fa-plus"></i> Post listing
            </a>
        }
        else
        {
            <a asp-controller="Listing" asp-action="Index" class="dash-nav-item">
                <i class="fa-solid fa-magnifying-glass"></i> Browse listings
            </a>
            <a asp-controller="Dashboard" asp-action="Favorites" class="dash-nav-item">
                <i class="fa-solid fa-heart"></i> Saved listings
            </a>
        }

        <a asp-controller="Account" asp-action="Profile" class="dash-nav-item active">
            <i class="fa-solid fa-user"></i> Profile
        </a>

        <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:auto">
            @Html.AntiForgeryToken()
            <button type="submit" class="dash-nav-item" style="color:#A32D2D;background:none;border:none;width:100%;text-align:left;cursor:pointer">
                <i class="fa-solid fa-right-from-bracket"></i> Log out
            </button>
        </form>
    </div>

    <!-- CONTENT -->
    <div class="dash-content">
        <div class="dash-header">
            <div class="dash-title">My profile</div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <div class="table-card" style="max-width:560px">
            <form asp-action="Profile" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="create-section-title" style="margin-bottom:16px">Account details</div>

                <div class="form-group" style="text-align:center;margin-bottom:24px">
                    @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                    {
                        <img src="@Model.ProfilePicture" style="width:80px;height:80px;border-radius:50%;object-fit:cover;margin-bottom:12px;display:block;margin-inline:auto" />
                    }
                    else
                    {
                        <div class="dash-avatar" style="width:80px;height:80px;font-size:28px;margin:0 auto 12px">
                            @(Model.FullName?[0].ToString().ToUpper() ?? "?")
                        </div>
                    }
                    <label class="btn btn-outline" style="cursor:pointer;font-size:13px">
                        <i class="fa-solid fa-camera"></i> Change photo
                        <input type="file" name="profileImage" accept="image/*" style="display:none" />
                    </label>
                </div>

                <div class="form-group">
                    <label>Full name</label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>Email address</label>
                    <input asp-for="Email" class="form-control" disabled style="opacity:0.6;cursor:not-allowed" />
                    <small style="color:#888">Email cannot be changed</small>
                </div>

                <div class="form-group">
                    <label>Phone number</label>
                    <input asp-for="Phone" class="form-control" placeholder="+256 7XX XXX XXX" />
                </div>

                <div class="create-section-title" style="margin:24px 0 16px">Change password</div>
                <small style="color:#888;display:block;margin-bottom:16px">Leave blank if you don't want to change your password</small>

                <div class="form-group">
                    <label>Current password</label>
                    <input asp-for="CurrentPassword" type="password" class="form-control" />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label>New password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div style="margin-top:24px">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-check"></i> Save changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>