@model List<GwaFind.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
        .notif-page {
            max-width: 680px;
            margin: 40px auto;
            padding: 0 16px;
        }

        .notif-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .notif-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #111;
        }

        .notif-clear {
            font-size: .82rem;
            color: #888;
            background: none;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            padding: 5px 12px;
            cursor: pointer;
            font-family: inherit;
            transition: all .15s;
        }

        .notif-clear:hover {
            background: #f5f5f5;
            color: #333;
        }

        .notif-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: 14px;
            margin-bottom: 8px;
            text-decoration: none;
            transition: background .15s;
            cursor: pointer;
            border: 1px solid transparent;
        }

        .notif-item.unread {
            background: #f0faf5;
            border-color: #c8eed9;
        }

        .notif-item.read {
            background: #fff;
            border-color: #ebebeb;
        }

        .notif-item:hover {
            filter: brightness(.97);
        }

        .notif-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .notif-dot.unread {
            background: #1a9e6e;
        }

        .notif-dot.read {
            background: transparent;
            border: 1.5px solid #ddd;
        }

        .notif-icon {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .notif-icon.green {
            background: #e8f8f1;
            color: #1a9e6e;
        }

        .notif-icon.yellow {
            background: #fef9e7;
            color: #d97706;
        }

        .notif-icon.red {
            background: #fef2f2;
            color: #dc2626;
        }

        .notif-icon.blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .notif-body {
            flex: 1;
            min-width: 0;
        }

        .notif-msg {
            font-size: .92rem;
            color: #111;
            font-weight: 500;
            line-height: 1.4;
        }

        .notif-item.read .notif-msg {
            font-weight: 400;
            color: #444;
        }

        .notif-time {
            font-size: .76rem;
            color: #aaa;
            margin-top: 3px;
        }

        .notif-empty {
            text-align: center;
            padding: 60px 20px;
        }

        .notif-empty i {
            font-size: 3rem;
            color: #ddd;
            margin-bottom: 12px;
            display: block;
        }

        .notif-empty p {
            color: #aaa;
            font-size: .95rem;
        }
</style>

<div class="notif-page">
    <div class="notif-header">
        <div class="notif-title">
            Notifications
            @{
                var unreadCount = Model.Count(n => !n.IsRead);
            }
            @if (unreadCount > 0)
            {
                <span style="background:#1a9e6e;color:#fff;font-size:.7rem;padding:2px 8px;border-radius:99px;font-weight:600;margin-left:8px;vertical-align:middle">
                    @unreadCount new
                </span>
            }
        </div>
        @if (Model.Any())
        {
            <form asp-action="ClearAll" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="notif-clear">Clear all</button>
            </form>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="notif-empty">
            <i class="fa-solid fa-bell-slash"></i>
            <p>You're all caught up!</p>
        </div>
    }
    else
    {
        foreach (var n in Model)
        {
            // Pick icon based on message content
            var iconClass = "blue";
            var iconName = "fa-bell";
            if (n.Message.Contains("approved") || n.Message.Contains("live"))
            { iconClass = "green"; iconName = "fa-circle-check"; }
            else if (n.Message.Contains("declined") || n.Message.Contains("flagged"))
            { iconClass = "red"; iconName = "fa-circle-xmark"; }
            else if (n.Message.Contains("inquiry") || n.Message.Contains("message"))
            { iconClass = "blue"; iconName = "fa-comment"; }
            else if (n.Message.Contains("pending") || n.Message.Contains("approval"))
            { iconClass = "yellow"; iconName = "fa-clock"; }

            <form asp-action="MarkRead" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@n.Id" />
                <button type="submit" class="notif-item @(n.IsRead ? "read" : "unread")" style="width:100%;text-align:left;font-family:inherit">
                    <div class="notif-dot @(n.IsRead ? "read" : "unread")"></div>
                    <div class="notif-icon @iconClass">
                        <i class="fa-solid @iconName"></i>
                    </div>
                    <div class="notif-body">
                        <div class="notif-msg">@n.Message</div>
                        <div class="notif-time">
                            @(n.CreatedAt.Date == DateTime.Today
                                                ? n.CreatedAt.ToString("h:mm tt") + " · Today"
                                                : n.CreatedAt.ToString("MMM d · h:mm tt"))
                        </div>
                    </div>
                    @if (!n.IsRead)
                    {
                        <i class="fa-solid fa-chevron-right" style="color:#1a9e6e;font-size:.75rem;flex-shrink:0"></i>
                    }
                </button>
            </form>
        }
    }
</div>