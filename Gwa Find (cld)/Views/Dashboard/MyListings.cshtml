@model List<GwaFind.Models.Listing>
@{
    ViewData["Title"] = "My Listings";
    var current = ViewBag.CurrentStatus as string ?? "All";
}

<div class="dash-layout">
    <!-- SIDEBAR -->
    <div class="dash-sidebar">
        <div class="dash-user">
            @if (!string.IsNullOrEmpty(ViewBag.ProfilePicture as string))
            {
                <img src="@ViewBag.ProfilePicture" class="dash-avatar-img" />
            }
            else
            {
                <div class="dash-avatar">@(ViewBag.FullName?[0].ToString().ToUpper() ?? "?")</div>
            }
            <div class="dash-user-name">@ViewBag.FullName</div>
            <div class="dash-user-role">Property owner</div>
        </div>

        <a asp-action="Index" class="dash-nav-item">
            <i class="fa-solid fa-chart-bar"></i> Dashboard
        </a>
        <a asp-action="MyListings" class="dash-nav-item active">
            <i class="fa-solid fa-list"></i> My listings
        </a>
        <a asp-controller="Listing" asp-action="Create" class="dash-nav-item">
            <i class="fa-solid fa-plus"></i> Post listing
        </a>
        <a asp-controller="Account" asp-action="Profile" class="dash-nav-item">
            <i class="fa-solid fa-user"></i> Profile
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:auto">
            @Html.AntiForgeryToken()
            <button type="submit" class="dash-nav-item" style="color:#A32D2D;background:none;border:none;width:100%;text-align:left;cursor:pointer">
                <i class="fa-solid fa-right-from-bracket"></i> Log out
            </button>
        </form>
    </div>

    <!-- CONTENT -->
    <div class="dash-content">
        <div class="dash-header">
            <div class="dash-title">My listings</div>
            <a asp-controller="Listing" asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i> Post new listing
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <!-- STATUS TABS -->
        <div class="status-tabs" style="display:flex;gap:8px;margin-bottom:24px;flex-wrap:wrap">
            @foreach (var tab in new[] { "All", "Active", "Pending", "Declined" })
            {
                var count = tab == "All" ? ViewBag.AllCount :
                tab == "Active" ? ViewBag.ActiveCount :
                tab == "Pending" ? ViewBag.PendingCount :
                ViewBag.DeclinedCount;
                <a asp-action="MyListings" asp-route-status="@tab"
                   class="btn @(current == tab ? "btn-primary" : "btn-outline")" style="gap:6px">
                    @tab <span style="background:rgba(0,0,0,0.1);padding:1px 7px;border-radius:99px;font-size:12px">@count</span>
                </a>
            }
        </div>

        <!-- TABLE -->
        <div class="table-card">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="fa-solid fa-house-circle-xmark"></i>
                    <p>No @(current == "All" ? "" : current.ToLower()) listings found.</p>
                    @if (current == "All")
                    {
                        <a asp-controller="Listing" asp-action="Create" class="btn btn-primary">Post your first listing</a>
                    }
                </div>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th>Property</th>
                            <th>Type</th>
                            <th>Price</th>
                            <th>Status</th>
                            <th>Inquiries</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var listing in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@listing.Title</strong><br />
                                    <small style="color:#888">@listing.Location, @listing.District</small>
                                </td>
                                <td>@listing.ListingType</td>
                                <td>UGX @listing.Price.ToString("N0")</td>
                                <td>
                                    <span class="badge badge-@listing.Status.ToLower()">@listing.Status</span>
                                </td>
                                <td>@(listing.Inquiries?.Count ?? 0)</td>
                                <td>
                                    <div style="display:flex;gap:6px">
                                        <a asp-controller="Listing" asp-action="Details" asp-route-id="@listing.Id" class="btn btn-sm">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" style="display:inline"
                                              onsubmit="return confirm('Delete this listing?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@listing.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>