@model List<GwaFind.Models.Favorite>
@{
    ViewData["Title"] = "Saved listings";
}

<div class="dash-layout">
    <!-- SIDEBAR -->
    <div class="dash-sidebar">
        <div class="dash-user">
            <div class="dash-avatar">@User.Identity.Name[0].ToString().ToUpper()</div>
            <div class="dash-user-name">@ViewBag.FullName</div>
            <div class="dash-user-role">House seeker</div>
        </div>

        <a asp-controller="Listing" asp-action="Index" class="dash-nav-item">
            <i class="fa-solid fa-magnifying-glass"></i> Browse listings
        </a>
        <a asp-action="Favorites" class="dash-nav-item active">
            <i class="fa-solid fa-heart"></i> Saved listings
        </a>
        <a asp-controller="Account" asp-action="Profile" class="dash-nav-item">
            <i class="fa-solid fa-user"></i> Profile
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:auto">
            @Html.AntiForgeryToken()
            <button type="submit" class="dash-nav-item" style="color:#A32D2D;background:none;border:none;width:100%;text-align:left;cursor:pointer">
                <i class="fa-solid fa-right-from-bracket"></i> Log out
            </button>
        </form>
    </div>

    <!-- CONTENT -->
    <div class="dash-content">
        <div class="dash-header">
            <div class="dash-title">Saved listings</div>
            <a asp-controller="Listing" asp-action="Index" class="btn btn-primary">
                <i class="fa-solid fa-magnifying-glass"></i> Browse more
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="fa-regular fa-heart"></i>
                <p>You haven't saved any listings yet.</p>
                <a asp-controller="Listing" asp-action="Index" class="btn btn-primary">Browse listings</a>
            </div>
        }
        else
        {
            <div class="listings-grid">
                @foreach (var fav in Model)
                {
                    var listing = fav.Listing;
                    var firstImage = listing.Images?.FirstOrDefault()?.ImagePath;

                    <div class="listing-card">
                        <a asp-controller="Listing" asp-action="Details" asp-route-id="@listing.Id" class="card-img-link">
                            @if (!string.IsNullOrEmpty(firstImage))
                            {
                                <img src="@firstImage" alt="@listing.Title" class="card-img" />
                            }
                            else
                            {
                                <div class="card-img-placeholder">
                                    <i class="fa-solid @(listing.PropertyType == "House" ? "fa-house" : "fa-building")"></i>
                                </div>
                            }
                        </a>
                        <div class="card-body">
                            <div class="card-price">
                                UGX @listing.Price.ToString("N0")
                                @if (listing.ListingType == "Rent")
                                {
                                    <span>/ @listing.PricePeriod?.ToLower()</span>
                                }
                            </div>
                            <div class="card-title">@listing.Title</div>
                            <div class="card-location">
                                <i class="fa-solid fa-location-dot"></i> @listing.Location, @listing.District
                            </div>
                            <div class="card-specs">
                                <span><i class="fa-solid fa-bed"></i> @listing.Bedrooms bd</span>
                                <span><i class="fa-solid fa-bath"></i> @listing.Bathrooms ba</span>
                                <span class="badge @(listing.ListingType == "Rent" ? "badge-rent" : "badge-sale")">
                                    @listing.ListingType
                                </span>
                            </div>
                            <div style="display:flex;gap:8px;margin-top:12px">
                                <a asp-controller="Listing" asp-action="Details" asp-route-id="@listing.Id"
                                   class="btn btn-sm btn-primary" style="flex:1;text-align:center">
                                    View listing
                                </a>
                                <form asp-controller="Listing" asp-action="RemoveFavorite" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="listingId" value="@listing.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Remove from saved?')">
                                        <i class="fa-solid fa-heart-crack"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>