@model List<GwaFind.Models.Message>
@{
    ViewData["Title"] = "Chat";
    var inquiryId = (int)ViewBag.InquiryId;
    var currentUserId = ViewBag.CurrentUserId as string;
    var inquiry = ViewBag.Inquiry as GwaFind.Models.Inquiry;
    var isOwner = (bool)ViewBag.IsOwner;
    var otherPerson = isOwner ? inquiry?.Seeker : inquiry?.Listing?.Owner;
}

<style>
    body {
        background: #f7f7f8;
    }

    main {
        padding: 0 !important;
    }

    .chat-page {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 64px);
        max-width: 780px;
        margin: 0 auto;
        background: #fff;
        border-left: 1px solid #ebebeb;
        border-right: 1px solid #ebebeb;
    }

    /* HEADER */
    .chat-head {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 20px;
        border-bottom: 1px solid #ebebeb;
        background: #fff;
        position: sticky;
        top: 64px;
        z-index: 10;
    }

    .chat-head-back {
        color: #555;
        text-decoration: none;
        font-size: 1rem;
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: background .15s;
    }

        .chat-head-back:hover {
            background: #f0f0f0;
        }

    .chat-head-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1a9e6e, #0d6e4a);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.1rem;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(26,158,110,.3);
    }

    .chat-head-info {
        flex: 1;
    }

    .chat-head-name {
        font-weight: 700;
        font-size: .97rem;
        color: #111;
    }

    .chat-head-sub {
        font-size: .78rem;
        color: #888;
        margin-top: 1px;
    }

    .chat-head-listing {
        font-size: .78rem;
        background: #f0faf5;
        color: #1a9e6e;
        border: 1px solid #b2dfce;
        border-radius: 99px;
        padding: 3px 10px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px;
    }

    /* MESSAGES AREA */
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px 20px 8px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        background: #fafafa;
    }

    .date-divider {
        text-align: center;
        font-size: .72rem;
        color: #aaa;
        margin: 12px 0 8px;
        position: relative;
    }

        .date-divider::before, .date-divider::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 28%;
            height: 1px;
            background: #e8e8e8;
        }

        .date-divider::before {
            left: 0;
        }

        .date-divider::after {
            right: 0;
        }

    .msg-group {
        margin-top: 10px;
    }

    .sender-label {
        font-size: .72rem;
        font-weight: 600;
        color: #1a9e6e;
        margin-bottom: 3px;
        padding-left: 2px;
    }

    .mine .sender-label {
        text-align: right;
        padding-right: 2px;
        color: #888;
    }

    .bubble-row {
        display: flex;
        align-items: flex-end;
        gap: 6px;
        margin-bottom: 2px;
    }

        .bubble-row.mine {
            flex-direction: row-reverse;
        }

        .bubble-row.theirs {
            flex-direction: row;
        }

    .bubble {
        max-width: 75%;
        padding: 9px 13px;
        font-size: .92rem;
        line-height: 1.45;
        word-break: break-word;
        position: relative;
    }

        .bubble.mine {
            background: #1a9e6e;
            color: #fff;
            border-radius: 18px 18px 4px 18px;
            box-shadow: 0 1px 4px rgba(26,158,110,.2);
        }

        .bubble.theirs {
            background: #fff;
            color: #111;
            border-radius: 18px 18px 18px 4px;
            border: 1px solid #ebebeb;
            box-shadow: 0 1px 3px rgba(0,0,0,.06);
        }

    .bubble-footer {
        display: flex;
        align-items: center;
        gap: 4px;
        margin-top: 3px;
        font-size: .68rem;
    }

        .bubble-footer.mine {
            justify-content: flex-end;
            color: rgba(255,255,255,.7);
        }

        .bubble-footer.theirs {
            justify-content: flex-start;
            color: #aaa;
        }

    .tick {
        font-size: .72rem;
    }

        .tick.read {
            color: #a8e6cf;
        }

        .tick.unread {
            color: rgba(255,255,255,.5);
        }

    /* INPUT BAR */
    .chat-input-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        border-top: 1px solid #ebebeb;
        background: #fff;
    }

    .chat-input {
        flex: 1;
        border: 1.5px solid #e0e0e0;
        border-radius: 24px;
        padding: 10px 18px;
        font-size: .93rem;
        outline: none;
        background: #f7f7f8;
        font-family: inherit;
        color: #111;
        transition: border .2s;
    }

        .chat-input:focus {
            border-color: #1a9e6e;
            background: #fff;
        }

    .chat-send {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #1a9e6e;
        border: none;
        color: #fff;
        font-size: .95rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background .15s, transform .1s;
        box-shadow: 0 2px 8px rgba(26,158,110,.3);
    }

        .chat-send:hover {
            background: #168a5e;
        }

        .chat-send:active {
            transform: scale(.93);
        }
</style>

<div class="chat-page">

    <!-- Header -->
    <div class="chat-head">
        <a href="/Chat" class="chat-head-back"><i class="fa-solid fa-arrow-left"></i></a>
        <div class="chat-head-avatar">@((otherPerson?.FullName ?? "U")[0].ToString().ToUpper())</div>
        <div class="chat-head-info">
            <div class="chat-head-name">@(otherPerson?.FullName ?? otherPerson?.Email ?? "User")</div>
            <div class="chat-head-sub">@(isOwner ? "House Seeker" : "Property Owner")</div>
        </div>
        <div class="chat-head-listing" title="@inquiry?.Listing?.Title">
            <i class="fa-solid fa-house" style="font-size:.7rem"></i>
            @inquiry?.Listing?.Title
        </div>
    </div>

    <!-- Messages -->
    <div class="chat-messages" id="msgBox">
        @if (!Model.Any())
        {
            <div style="text-align:center;margin-top:60px">
                <div style="font-size:2.5rem;margin-bottom:10px">👋</div>
                <div style="font-weight:600;color:#333;font-size:.97rem">Start the conversation</div>
                <div style="color:#aaa;font-size:.83rem;margin-top:4px">Say hi to get things going</div>
            </div>
        }

        @{
            string? lastSenderId = null;
            string? lastDate = null;
        }

        @foreach (var msg in Model)
        {
            var mine = msg.SenderId == currentUserId;
            var msgDate = msg.SentAt.ToString("MMM d, yyyy");
            var showDate = msgDate != lastDate;
            var showName = msg.SenderId != lastSenderId;
            lastSenderId = msg.SenderId;
            lastDate = msgDate;

            if (showDate)
            {
                <div class="date-divider">@(msg.SentAt.Date == DateTime.Today ? "Today" : msg.SentAt.Date == DateTime.Today.AddDays(-1) ? "Yesterday" : msgDate)</div>
            }

            <div class="bubble-row @(mine ? "mine" : "theirs")">
                @* <div style="display:flex;flex-direction:column;align-items:@(mine ? "flex-end" : "flex-start");max-width:62%"> *@
                <div style="display:flex;flex-direction:column;align-items:@(mine ? "flex-end" : "flex-start");max-width:75%">
                    @if (showName && !mine)
                    {
                        <div class="sender-label">@(msg.Sender?.FullName ?? "User")</div>
                    }
                    <div class="bubble @(mine ? "mine" : "theirs")">
                        @msg.Content
                    </div>
                    <div class="bubble-footer @(mine ? "mine" : "theirs")">
                        <span>@msg.SentAt.ToString("h:mm tt")</span>
                        @if (mine)
                        {
                            <span class="tick @(msg.IsRead ? "read" : "unread")">
                                @if (msg.IsRead)
                                {
                                    <i class="fa-solid fa-check-double"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-check-double"></i>
                                }
                            </span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Input -->
    <form asp-action="Send" asp-controller="Chat" method="post" class="chat-input-bar">
        @Html.AntiForgeryToken()
        <input type="hidden" name="inquiryId" value="@inquiryId" />
        <input type="text" name="content" id="msgInput" class="chat-input" placeholder="Type a message..." autocomplete="off" />
        <button type="submit" class="chat-send">
            <i class="fa-solid fa-paper-plane"></i>
        </button>
    </form>
</div>

@section Scripts {
    <script>
        const box = document.getElementById('msgBox');
        box.scrollTop = box.scrollHeight;
        document.getElementById('msgInput').focus();

        // Send on Enter
        document.getElementById('msgInput').addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                this.closest('form').submit();
            }
        });
    </script>
}