@model GwaFind.Models.Listing
@{
    ViewData["Title"] = "Edit Listing";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dash-layout">
    <!-- SIDEBAR -->
    <div class="dash-sidebar">
        <div class="dash-user">
            @if (!string.IsNullOrEmpty(ViewBag.ProfilePicture as string))
            {
                <img src="@ViewBag.ProfilePicture" class="dash-avatar-img" />
            }
            else
            {
                <div class="dash-avatar">@(ViewBag.FullName?[0].ToString().ToUpper() ?? "?")</div>
            }
            <div class="dash-user-name">@ViewBag.FullName</div>
            <div class="dash-user-role">Property owner</div>
        </div>

        <a asp-controller="Dashboard" asp-action="Index" class="dash-nav-item">
            <i class="fa-solid fa-chart-bar"></i> Dashboard
        </a>
        <a asp-controller="Dashboard" asp-action="MyListings" class="dash-nav-item active">
            <i class="fa-solid fa-list"></i> My listings
        </a>
        <a asp-controller="Listing" asp-action="Create" class="dash-nav-item">
            <i class="fa-solid fa-plus"></i> Post listing
        </a>
        <a asp-controller="Account" asp-action="Profile" class="dash-nav-item">
            <i class="fa-solid fa-user"></i> Profile
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:auto">
            @Html.AntiForgeryToken()
            <button type="submit" class="dash-nav-item" style="color:#A32D2D;background:none;border:none;width:100%;text-align:left;cursor:pointer">
                <i class="fa-solid fa-right-from-bracket"></i> Log out
            </button>
        </form>
    </div>

    <!-- CONTENT -->
    <div class="dash-content">
        <div class="dash-header">
            <div class="dash-title">Edit listing</div>
            <a asp-controller="Dashboard" asp-action="MyListings" class="btn btn-outline">
                <i class="fa-solid fa-arrow-left"></i> Back
            </a>
        </div>

        <div class="alert" style="background:#FFF8E1;border:1px solid #FFD54F;color:#7a5c00;border-radius:10px;padding:12px 16px;margin-bottom:20px;font-size:.93rem;">
            <i class="fa-solid fa-clock"></i>
            Saving changes will reset this listing to <strong>Pending</strong> — admin will need to re-approve it.
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <div class="table-card" style="padding:28px">
            <form asp-action="Edit" asp-controller="Listing" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="row g-3" style="display:grid;grid-template-columns:1fr 1fr;gap:16px">

                    <div style="grid-column:1/-1">
                        <label class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div>
                        <label class="form-label">Listing Type</label>
                        <select asp-for="ListingType" class="form-select">
                            <option value="Rent">Rent</option>
                            <option value="Sale">Sale</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Property Type</label>
                        <select asp-for="PropertyType" class="form-select">
                            <option value="House">House</option>
                            <option value="Apartment">Apartment</option>
                            <option value="Land">Land</option>
                            <option value="Commercial">Commercial</option>
                        </select>
                    </div>

                    <div>
                        <label class="form-label">Price (UGX)</label>
                        <input asp-for="Price" class="form-control" type="number" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div>
                        <label class="form-label">Location</label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <div>
                        <label class="form-label">District</label>
                        <input asp-for="District" class="form-control" />
                    </div>

                    <div>
                        <label class="form-label">Area (sqm) <span style="color:#aaa;font-weight:400">(optional)</span></label>
                        <input asp-for="AreaSqM" class="form-control" type="number" />
                    </div>

                    <div>
                        <label class="form-label">Bedrooms</label>
                        <input asp-for="Bedrooms" class="form-control" type="number" />
                    </div>

                    <div>
                        <label class="form-label">Bathrooms</label>
                        <input asp-for="Bathrooms" class="form-control" type="number" />
                    </div>

                    <div style="grid-column:1/-1">
                        <label class="form-label">Amenities <span style="color:#aaa;font-weight:400">(optional)</span></label>
                        <input asp-for="Amenities" class="form-control" placeholder="e.g. Parking, WiFi, Water included" />
                    </div>

                    <div style="grid-column:1/-1">
                        <label class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Existing Images -->
                @if (Model.Images != null && Model.Images.Any())
                {
                    <div style="margin-top:24px">
                        <label class="form-label">Current Images</label>
                        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:8px">
                            @foreach (var img in Model.Images)
                            {
                                <div style="position:relative;width:110px">
                                    <img src="@img.ImagePath" style="width:110px;height:80px;object-fit:cover;border-radius:8px;" />
                                    <form asp-action="DeleteImage" asp-controller="Listing" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="imageId" value="@img.Id" />
                                        <input type="hidden" name="listingId" value="@Model.Id" />
                                        <button type="submit" onclick="return confirm('Remove this image?')"
                                                style="position:absolute;top:4px;right:4px;background:#e53935;color:#fff;border:none;border-radius:50%;width:22px;height:22px;font-size:11px;cursor:pointer;line-height:1">
                                            <i class="fa-solid fa-times"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Add New Images -->
                <div style="margin-top:24px">
                    <label class="form-label">Add More Images</label>
                    <input type="file" id="newImageInput" name="NewImages" class="form-control" multiple accept="image/*" />
                    <div id="newImagePreview" style="display:flex;flex-wrap:wrap;gap:10px;margin-top:10px"></div>
                </div>

                <div style="margin-top:28px;display:flex;gap:10px">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-save"></i> Save changes
                    </button>
                    <a asp-controller="Dashboard" asp-action="MyListings" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('newImageInput').addEventListener('change', function () {
            const preview = document.getElementById('newImagePreview');
            preview.innerHTML = '';
            Array.from(this.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = e => {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.cssText = 'width:110px;height:80px;object-fit:cover;border-radius:8px;';
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        });
    </script>
}